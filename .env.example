# Environment
ENVIRONMENT=development

# LLM Provider (openai, gemini, anthropic, avalai, mimo)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# API Keys (set the one matching your LLM_PROVIDER)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
AVALAI_API_KEY=
AVALAI_BASE_URL=https://api.avalai.ir/v1
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# Admin
ADMIN_API_KEY=dev-admin-key-change-this

# Analysis auth (leave empty for open access)
ANALYSIS_API_KEY=

# CORS (comma-separated origins; defaults to localhost in dev)
CORS_ALLOWED_ORIGINS=

# Database
DATABASE_URL=sqlite+aiosqlite:///./talent_pool.db

# Talent pool storage
TALENT_POOL_ROOT=./talent-pool

# Sentry (optional)
SENTRY_DSN=
SENTRY_SEND_PII=false

# Cloudflare Turnstile (optional — if set, /analyze requires valid token)
TURNSTILE_SECRET_KEY=
